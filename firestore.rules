rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    function groupDoc(groupId) {
      return get(/databases/$(database)/documents/groups/$(groupId)).data;
    }

    function isGroupMember(groupId) {
      return isAuthed() &&
             request.auth.uid in groupDoc(groupId).memberIds;
    }

    function isGroupCreator(groupId) {
      return isAuthed() &&
             request.auth.uid == groupDoc(groupId).createdBy;
    }

    // Allowed when the only change to memberIds is the requester adding themselves
    // (used for the "join via invite code" flow).
    function isSelfJoin() {
      return isAuthed() &&
             !(request.auth.uid in resource.data.memberIds) &&
             request.auth.uid in request.resource.data.memberIds &&
             request.resource.data.diff(resource.data)
                .affectedKeys().hasOnly(['memberIds']);
    }

    // ─── USERS ────────────────────────────────────────────────────────────
    // Any authenticated user can read user docs (needed to render member info
    // in groups). The owner is the only one who can write/delete.
    match /users/{uid} {
      allow read: if isAuthed();
      allow create, update, delete: if isOwner(uid);
    }

    // ─── GROUPS ──────────────────────────────────────────────────────────
    match /groups/{groupId} {

      // GET any group doc if authenticated (needed for invite-code join flow
      // and viewing groups where you're a member). LIST is restricted: the
      // client only queries by `memberIds arrayContains uid` or by inviteCode.
      allow get: if isAuthed();
      allow list: if isAuthed();

      // Create: must include yourself in memberIds AND be the creator.
      allow create: if isAuthed() &&
                       request.resource.data.createdBy == request.auth.uid &&
                       request.auth.uid in request.resource.data.memberIds;

      // Update: existing member OR non-member adding only themselves (join).
      allow update: if isAuthed() && (
                       (request.auth.uid in resource.data.memberIds) ||
                       isSelfJoin()
                    );

      // Delete: only the creator can delete the group document.
      allow delete: if isAuthed() &&
                       request.auth.uid == resource.data.createdBy;

      // ─── ACTIVITY (subcollection) ───────────────────────────────────────
      // Read: any member of the parent group.
      // Create: any authed user can write an entry tagged with their own uid.
      // Delete: own entries OR the group creator (for cascading group delete).
      match /activity/{docId} {
        allow read: if isGroupMember(groupId);
        allow create: if isAuthed() &&
                         request.resource.data.uid == request.auth.uid;
        allow update: if false; // activity is immutable
        allow delete: if isAuthed() && (
                         request.auth.uid == resource.data.uid ||
                         isGroupCreator(groupId)
                      );
      }

      // ─── PER-GROUP AVAILABILITY OVERRIDES (subcollection) ───────────────
      // Doc ID must equal the writer's uid.
      // Read: any member of the parent group.
      // Write/delete: only the owning user.
      match /availabilities/{uid} {
        allow read: if isGroupMember(groupId);
        allow create, update, delete: if isOwner(uid);
      }
    }

    // Default deny for anything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
